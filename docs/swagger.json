                "genero",
                "nome",
                "senha",
                "sobrenome"
            ],
            "properties": {
                "data_nascimento": {
                    "type": "string"
                },
                "email": {
                    "type": "string"
                },
                "genero": {
                    "type": "string",
                    "enum": [
                        "M",
                        "F",
                        "O"
                    ]
                },
                "nome": {
                    "type": "string",
                    "maxLength": 100,
                    "minLength": 2
                },
                "senha": {
                    "type": "string",
                    "minLength": 6
                },
                "sobrenome": {
                    "type": "string",
                    "maxLength": 100,
                    "minLength": 2
